#!/usr/bin/env bash

# helpful https://macos-defaults.com/

if [[ $EUID -ne 0 ]]; then
  RUN_AS_ROOT=false
  printf "Certain commands will not be run without sudo privileges. To run as root, run the same command prepended with 'sudo', for example: $ sudo $0\n\n" | fold -s -w 80
else
  RUN_AS_ROOT=true
  # Update existing `sudo` timestamp until `.osx` has finished
  while true; do sudo -n true; sleep 60; kill -0 "$$" || exit; done 2>/dev/null &
fi

###############################################################################
# Dock
###############################################################################

defaults write com.apple.dock "mineffect" -string "scale"
defaults write com.apple.dock "mru-spaces" -bool "false"
defaults write com.apple.dock launchanim -bool "false"

# Set the icon size of Dock items
defaults write com.apple.dock tilesize -int 40
defaults write com.apple.dock orientation left
defaults write com.apple.dock show-recents -bool "false"

# Speed up Mission Control animations
defaults write com.apple.dock expose-animation-duration -float 0.1

# Disable Quick Note on the bottom-right hot corner.
defaults write com.apple.dock wvous-br-corner -int 0
defaults write com.apple.dock wvous-br-modifier -int 0

###############################################################################
# Misc
###############################################################################
chflags nohidden ~/Library

mkdir -p ~/Documents/Screenshots
defaults write com.apple.screencapture "location" -string "~/Documents/Screenshots"
defaults write com.apple.screencapture "disable-shadow" -bool "true"

defaults write com.apple.LaunchServices "LSQuarantine" -bool "false"
defaults write NSGlobalDomain "ApplePressAndHoldEnabled" -bool "false"
defaults write com.apple.print.PrintingPrefs "Quit When Finished" -bool "true"
defaults write com.apple.HIToolbox AppleFnUsageType -int 0

disabled_service_status_xml='<dict><key>enabled_context_menu</key><false/><key>enabled_services_menu</key><false/><key>presentation_modes</key><dict><key>ContextMenu</key><false/><key>ServicesMenu</key><false/></dict></dict>'
defaults write pbs NSServicesStatus -dict-add "com.apple.Terminal - Open man Page in Terminal - openManPage" "$disabled_service_status_xml"
defaults write pbs NSServicesStatus -dict-add "com.apple.Terminal - Search man Page Index in Terminal - searchManPages" "$disabled_service_status_xml"

# Finder settings
defaults write com.apple.finder "QuitMenuItem" -bool "true"
defaults write com.apple.finder "ShowPathbar" -bool "true"
defaults write com.apple.finder "FXPreferredViewStyle" -string "Nlsv"
defaults write com.apple.finder NewWindowTarget -string "PfHo"
defaults write NSGlobalDomain "NSTableViewDefaultSizeMode" -int "1"
defaults write NSGlobalDomain "NSNavPanelExpandedStateForSaveMode" -bool "true"
defaults write NSGlobalDomain "NSNavPanelExpandedStateForSaveMod2" -bool "true"
defaults write NSGlobalDomain "NSDocumentSaveNewDocumentsToCloud" -bool "false"
defaults write NSGlobalDomain "AppleShowAllExtensions" -bool "true"
defaults write NSGlobalDomain com.apple.springing.delay -float 1.0
defaults write -g com.apple.keyboard.fnState -int 1
defaults write -g com.apple.mouse.scaling -float 0.5
# Lock immediately and start the screen saver after 1 hour of inactivity.
defaults write com.apple.screensaver askForPassword -int 1
defaults write com.apple.screensaver askForPasswordDelay -int 0
defaults -currentHost write com.apple.screensaver idleTime -int 3600
#defaults write NSGlobalDomain "KeyRepeat" -int 50
#defaults write NSGlobalDomain "InitialKeyRepeat" -int 15

defaults write com.apple.AppleMultitouchTrackpad FirstClickThreshold -int 0
defaults write com.apple.AppleMultitouchTrackpad SecondClickThreshold -int 0

if [[ "${RUN_AS_ROOT}" == true ]]; then
  pmset -b displaysleep 60
  pmset -c displaysleep 0
fi

#Startup at login
#osascript -e 'tell application "System Events" to make login item at end with properties {path:"/Applications/MiddleClick.app", hidden:true}'
#osascript -e 'tell application "System Events" to make login item at end with properties {path:"/Applications/Docker.app", hidden:true}'
#brew services restart skhd
#brew services restart yabai

#custom apps config
#FIXME doesnt work on anymore (at least for shortcut)
#defaults write com.lwouis.alt-tab-macos.plist "hideWindowlessApps" -string true
#defaults write com.lwouis.alt-tab-macos.plist "holdShortcut" -string "⌘"
#defaults write com.lwouis.alt-tab-macos.plist "showOnScreen" 2

###############################################################################
# Kill/restart affected applications                                          #
###############################################################################

# Restart affected applications if `--no-restart` flag is not present.
if [[ ! ($* == *--no-restart*) ]]; then
  for app in "cfprefsd" "Dock" "Finder" "SystemUIServer" "AltTab"; do
    killall "${app}" > /dev/null 2>&1
  done
  open -a AltTab

fi

printf "Please log out and log back in to make all settings take effect.\n"
